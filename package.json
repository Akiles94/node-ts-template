{
  "name": "node-ts-template",
  "version": "1.0.0",
  "description": "Node.js + TypeScript REST API starter template with Hexagonal Architecture, Drizzle ORM, SQL-first migrations, and context-based scaffolding. Built with pnpm, Vitest, ESLint, and Prettier.",
  "type": "module",
  "scripts": {
    "dev": "node --conditions=development --import tsx ./src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "imports": {
    "#/*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
